{
  "prds": {
    "1": {
      "id": "PRD-20260418-001",
      "version": "1.0.0",
      "title": "Microservices Cookiecutter Template",
      "description": "A production-ready cookiecutter template for generating Kubernetes-deployed microservices with standardized Helm charts, Docker infrastructure, ArgoCD integration, and cross-service conventions.",
      "requirements": [
        {
          "id": "REQ-001",
          "title": "Cookiecutter Template Structure",
          "description": "Define cookiecutter.json with all variables needed to generate a microservice",
          "priority": "high",
          "acceptance_criteria": [
            "cookiecutter.json defines service name, language, package name, Python/Go/Node.js versions",
            "All {{ cookiecutter.* }} placeholders are resolvable from the manifest",
            "Pre-generation hook validates inputs (slugs, identifiers, version format)",
            "Post-generation hook initializes git, creates initial commit, optionally creates GitHub repo"
          ]
        },
        {
          "id": "REQ-002",
          "title": "Helm Chart Templates",
          "description": "Generate production-ready Helm charts for Kubernetes deployment",
          "priority": "high",
          "acceptance_criteria": [
            "Chart.yaml with correct apiVersion and dependencies",
            "values.yaml with dev defaults (3 replicas, 10Gi storage, configurable heap)",
            "StatefulSet template for stateful workloads with ordered scaling",
            "Service template supporting ClusterIP and headless service modes",
            "ConfigMap for environment variable injection",
            "PersistentVolumeClaim templates with configurable storage class",
            "Liveness and readiness probes (TCP and exec-based options)",
            "Pod anti-affinity for distributing replicas across nodes",
            "Helper templates for consistent labels and naming"
          ]
        },
        {
          "id": "REQ-003",
          "title": "Dockerfile and Image Strategy",
          "description": "Minimal, language-agnostic Dockerfile using official base images",
          "priority": "high",
          "acceptance_criteria": [
            "Dockerfile uses official base images (python:3.x, golang:1.x, node:18)",
            "Health check configured for container orchestration",
            "JVM tuning options for Java services (G1GC, heap size)",
            "Environment variable configuration via Helm",
            "Image size optimized (no build dependencies in final layer)"
          ]
        },
        {
          "id": "REQ-004",
          "title": "Docker Compose for Local Development",
          "description": "docker-compose.yml for local development without Kubernetes",
          "priority": "high",
          "acceptance_criteria": [
            "Compose file mirrors production Helm configuration",
            "Health checks for service dependencies (ordering)",
            "Volume mounts for code and data persistence",
            "Port mappings for local testing",
            "Environment variable configuration matching Helm"
          ]
        },
        {
          "id": "REQ-005",
          "title": "ArgoCD Integration",
          "description": "ApplicationSet template for GitOps-based deployment",
          "priority": "high",
          "acceptance_criteria": [
            "ApplicationSet with templated generators for multi-env deployment",
            "Auto-prune and self-heal enabled",
            "Retry logic (5 attempts, exponential backoff to 3m)",
            "Ignore rules for immutable resources (PVCs, StatefulSet rolling)",
            "Manifest location follows convention (argocd/applicationset.yaml)"
          ]
        },
        {
          "id": "REQ-006",
          "title": "Makefile / Taskfile Automation",
          "description": "Common development and deployment commands",
          "priority": "medium",
          "acceptance_criteria": [
            "deploy: Helm install to current cluster",
            "deploy-dev: Deploy with dev overrides (smaller resources)",
            "validate: Helm lint and dry-run",
            "logs: Stream logs from pods",
            "test: Run integration tests",
            "clean: Remove deployed resources and artifacts"
          ]
        },
        {
          "id": "REQ-007",
          "title": "GitHub Actions CI/CD Workflow",
          "description": "Pre-configured CI/CD for generated services",
          "priority": "medium",
          "acceptance_criteria": [
            "Lint and validation on push/PR",
            "Build and test on all branches",
            "Container image build and push on main/master",
            "Helm chart lint and dry-run",
            "Integration with semantic-release (if applicable to service)"
          ]
        },
        {
          "id": "REQ-008",
          "title": "Documentation Structure",
          "description": "Standardized documentation for all generated services",
          "priority": "medium",
          "acceptance_criteria": [
            "DEPLOYMENT.md: Helm, ArgoCD, and cloud-specific instructions",
            "DEVELOPMENT.md: Local setup (docker-compose, prerequisites)",
            "OPERATIONS.md: Troubleshooting, monitoring, scaling guidelines",
            "README.md with quick start and links to docs",
            "CLAUDE.md with project rules and guidelines"
          ]
        },
        {
          "id": "REQ-009",
          "title": "Cross-Repository Rules Integration",
          "description": "Import shared conventions from ../shared-claude-rules/",
          "priority": "medium",
          "acceptance_criteria": [
            "CLAUDE.md imports @shared-claude-rules/workflow/git.md (Conventional Commits, semantic-release)",
            "CLAUDE.md imports @shared-claude-rules/workflow/docs.md (documentation standards)",
            "CLAUDE.md imports @shared-claude-rules/testing.md (testing conventions)",
            "CLAUDE.md imports @shared-claude-rules/secrets.md (secrets management)",
            "All generated projects follow inherited rules"
          ]
        },
        {
          "id": "REQ-010",
          "title": "Multi-Language Support",
          "description": "Support Python, Go, and Node.js services with language-specific defaults",
          "priority": "medium",
          "acceptance_criteria": [
            "Python: Poetry, pytest, pytest-asyncio, black, commitizen",
            "Go: go mod, cobra CLI framework (if applicable), testing package",
            "Node.js: npm/yarn, jest, TypeScript (optional), commitizen",
            "Language selection via cookiecutter prompt",
            "Post-hook installs language-specific dependencies and tooling"
          ]
        },
        {
          "id": "REQ-011",
          "title": "Health Checks and Observability Patterns",
          "priority": "low",
          "description": "Baked-in patterns for health checks, logging, and metrics",
          "acceptance_criteria": [
            "Liveness and readiness probes (TCP, HTTP, exec)",
            "Structured logging patterns (JSON format, standard log levels)",
            "Prometheus metrics exporter stub (language-specific)",
            "Distributed tracing instrumentation (optional)"
          ]
        },
        {
          "id": "REQ-012",
          "title": "Template Validation and Testing",
          "description": "Automated validation of generated services",
          "priority": "high",
          "acceptance_criteria": [
            "Cookiecutter pre-generation hook validates all inputs",
            "Post-generation hook tests Helm template rendering",
            "Docker image builds successfully",
            "docker-compose up succeeds and services are healthy",
            "Generated project can be pushed to GitHub and deployed"
          ]
        }
      ],
      "acceptance_criteria": [],
      "validation_rules": {},
      "created_at": "2026-04-18 21:17:58",
      "pipeline_id": null,
      "status": "active",
      "priority": "high",
      "tags": [
        "infrastructure",
        "kubernetes",
        "cookiecutter",
        "helm",
        "q2-2026"
      ],
      "owner": "James Anthonyrajah",
      "target_date": "2026-06-30",
      "notes": null,
