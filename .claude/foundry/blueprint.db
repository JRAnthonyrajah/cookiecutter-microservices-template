  "plans": {
    "1": {
      "id": "PLAN-20260418-001",
      "version": "2.0.0",
      "prd_id": "PRD-20260418-001",
      "title": "Implementation Plan: Microservices Cookiecutter Template",
      "description": "Decomposed implementation plan for building a production-ready cookiecutter template that generates Kubernetes-deployed microservices with Helm charts, Docker infrastructure, ArgoCD integration, and cross-service conventions.",
      "steps": [],
      "task_definitions": [
        {
          "id": "TASK-001",
          "title": "Design cookiecutter.json manifest",
          "description": "Define all variables (service name, language, package name, versions, GitHub options) and their defaults",
          "dependencies": [],
          "specification": {
            "variables": [
              "service_name",
              "service_slug",
              "language",
              "package_name",
              "version",
              "author",
              "email",
              "python_version",
              "go_version",
              "node_version",
              "create_github_repo",
              "repo_visibility"
            ],
            "validation": "pre_gen_project hook validates slugs, identifiers, versions"
          },
          "inputs": {},
          "outputs": {
            "manifest": "cookiecutter.json"
          },
          "estimated_cost": 4.0
        },
        {
          "id": "TASK-002",
          "title": "Implement pre_gen_project.py validation hook",
          "description": "Validate inputs before template generation (slug regex, valid Python identifier, version format)",
          "dependencies": [
            "TASK-001"
          ],
          "specification": {
            "validations": [
              "slug matches [a-z0-9_]+",
              "package_name is valid Python identifier",
              "version matches semver",
              "language in [python, go, nodejs]"
            ],
            "error_messages": "Clear, actionable error messages for each validation"
          },
          "inputs": {
            "manifest": "cookiecutter.json"
          },
          "outputs": {
            "hook": "hooks/pre_gen_project.py"
          },
          "estimated_cost": 5.0
        },
        {
          "id": "TASK-003",
          "title": "Create Helm Chart.yaml template",
          "description": "Generate Chart.yaml with correct apiVersion, dependencies, and metadata",
          "dependencies": [],
          "specification": {
            "apiVersion": "v2",
            "dependencies": "Bitnami Zookeeper (conditional), other common dependencies",
            "templating": "Use {{ cookiecutter.* }} for service name, version, description"
          },
          "inputs": {},
          "outputs": {
            "chart": "{{ cookiecutter.service_slug }}/helm/Chart.yaml"
          },
          "estimated_cost": 3.0
        },
        {
          "id": "TASK-004",
          "title": "Create Helm values.yaml with dev defaults",
          "description": "Define dev environment defaults (3 replicas, 10Gi storage, 512m-1g heap, etc.)",
          "dependencies": [],
          "specification": {
            "replicas": 3,
            "storage": "10Gi",
            "heap_size": "512m-1g",
            "compression": "snappy",
            "image_pull_policy": "IfNotPresent"
          },
          "inputs": {},
          "outputs": {
            "values": "{{ cookiecutter.service_slug }}/helm/values.yaml"
          },
          "estimated_cost": 4.0
        },
        {
          "id": "TASK-005",
          "title": "Create Helm StatefulSet template",
          "description": "Generate StatefulSet for stateful workloads with ordered scaling and probes",
          "dependencies": [
            "TASK-003",
            "TASK-004"
          ],
          "specification": {
            "workload_type": "StatefulSet",
            "ordering": "Ordered pod names (service-0, service-1, etc.)",
            "probes": [
              "liveness: TCP socket",
              "readiness: exec or HTTP"
            ],
            "affinity": "Pod anti-affinity for replica distribution",
            "env_vars": "From ConfigMap and secrets"
          },
          "inputs": {
            "chart": "Chart.yaml",
            "values": "values.yaml"
          },
          "outputs": {
            "template": "{{ cookiecutter.service_slug }}/helm/templates/statefulset.yaml"
          },
          "estimated_cost": 7.0
        },
        {
          "id": "TASK-006",
          "title": "Create Helm Service template",
          "description": "Generate Service supporting ClusterIP and headless modes",
          "dependencies": [
            "TASK-003"
          ],
          "specification": {
            "service_types": [
              "ClusterIP (default)",
              "headless for StatefulSet"
            ],
            "ports": "Configurable from values",
            "selectors": "Match StatefulSet labels"
          },
          "inputs": {
            "chart": "Chart.yaml"
          },
          "outputs": {
            "template": "{{ cookiecutter.service_slug }}/helm/templates/service.yaml"
          },
          "estimated_cost": 3.0
        },
        {
          "id": "TASK-007",
          "title": "Create Helm ConfigMap and PVC templates",
          "description": "Generate ConfigMap for env vars and PVC for persistent storage",
          "dependencies": [
            "TASK-003"
          ],
          "specification": {
            "configmap": "Inject environment variables from values",
            "pvc": "PersistentVolumeClaim with configurable storage class",
            "templating": "Use {{ cookiecutter.* }} for defaults"
          },
          "inputs": {
            "chart": "Chart.yaml"
          },
          "outputs": {
            "templates": [
              "{{ cookiecutter.service_slug }}/helm/templates/configmap.yaml",
              "{{ cookiecutter.service_slug }}/helm/templates/pvc.yaml"
            ]
          },
          "estimated_cost": 4.0
        },
        {
          "id": "TASK-008",
          "title": "Create Helm helpers template",
          "description": "Generate _helpers.tpl with consistent labels and naming functions",
          "dependencies": [
            "TASK-003"
          ],
          "specification": {
            "helpers": [
              "labels",
              "name",
              "chart",
              "selectorLabels"
            ],
            "consistency": "Ensure all templates use the same naming convention"
          },
          "inputs": {
            "chart": "Chart.yaml"
          },
          "outputs": {
            "template": "{{ cookiecutter.service_slug }}/helm/templates/_helpers.tpl"
          },
          "estimated_cost": 3.0
        },
        {
          "id": "TASK-009",
          "title": "Create root values.yaml for production overrides",
          "description": "Create production environment overrides (50Gi, 1-2GB heap, etc.)",
          "dependencies": [
            "TASK-004"
          ],
          "specification": {
            "overrides": {
              "storage": "50Gi",
              "heap_size": "1g-2g",
              "replicas": "3-5",
              "storage_class": "aws-ebs"
            }
          },
          "inputs": {
            "dev_values": "helm/values.yaml"
          },
          "outputs": {
            "prod_values": "{{ cookiecutter.service_slug }}/values.yaml"
          },
          "estimated_cost": 2.0
        },
        {
          "id": "TASK-010",
          "title": "Create Dockerfile template",
          "description": "Generate language-specific Dockerfile with health checks and JVM tuning",
          "dependencies": [],
          "specification": {
            "languages": {
              "python": "python:3.x base, pip/poetry",
              "go": "golang:1.x build, minimal runtime",
              "nodejs": "node:18 base, npm/yarn"
            },
            "common": [
              "HEALTHCHECK instruction",
              "ENV variable configuration",
              "JVM tuning (if applicable)"
            ]
          },
          "inputs": {},
          "outputs": {
            "dockerfile": "{{ cookiecutter.service_slug }}/Dockerfile"
          },
          "estimated_cost": 5.0
        },
        {
          "id": "TASK-011",
          "title": "Create docker-compose.yml template",
          "description": "Generate docker-compose for local dev mirroring Helm configuration",
          "dependencies": [
            "TASK-010"
          ],
          "specification": {
            "services": "Single service + dependencies (if any)",
            "volumes": "Code and data persistence mounts",
            "environment": "Match Helm ConfigMap env vars",
            "health_checks": "Match liveness/readiness probes",
            "ports": "Expose service on localhost"
          },
          "inputs": {
            "dockerfile": "Dockerfile"
          },
          "outputs": {
            "compose": "{{ cookiecutter.service_slug }}/docker-compose.yml"
          },
          "estimated_cost": 4.0
        },
        {
          "id": "TASK-012",
          "title": "Create ArgoCD ApplicationSet template",
          "description": "Generate ApplicationSet for GitOps sync with auto-prune and retry logic",
          "dependencies": [
            "TASK-003"
          ],
          "specification": {
            "generators": "Templated for multi-env (dev, staging, prod)",
            "sync_policy": "auto-prune: true, selfHeal: true",
            "retry": "5 attempts, exponential backoff to 3m",
            "ignore_differences": "Ignore PVC and StatefulSet rolling changes"
          },
          "inputs": {
            "chart": "Chart.yaml"
          },
          "outputs": {
            "applicationset": "{{ cookiecutter.service_slug }}/argocd/applicationset.yaml"
          },
          "estimated_cost": 5.0
        },
        {
          "id": "TASK-013",
          "title": "Create GitHub Actions CI/CD workflow template",
          "description": "Generate .github/workflows/ci.yml for lint, test, build, and push",
          "dependencies": [
            "TASK-001"
          ],
          "specification": {
            "triggers": [
              "push to all branches",
              "PRs"
            ],
            "jobs": [
              "lint",
              "test",
              "build",
              "helm-lint",
              "push (on main/master only)"
            ]
          },
          "inputs": {},
          "outputs": {
            "workflow": "{{ cookiecutter.service_slug }}/.github/workflows/ci.yml"
          },
          "estimated_cost": 4.0
        },
        {
          "id": "TASK-014",
          "title": "Create Makefile/Taskfile with common commands",
          "description": "Generate automation file with deploy, validate, logs, test, clean targets",
          "dependencies": [
            "TASK-003",
            "TASK-011"
          ],
          "specification": {
            "targets": {
              "deploy": "helm install to current cluster",
              "deploy-dev": "helm install with dev overrides",
              "validate": "helm lint + dry-run",
              "logs": "kubectl logs streaming",
              "test": "Run integration tests",
              "clean": "Remove resources"
            }
          },
          "inputs": {
            "helm": "helm/",
            "compose": "docker-compose.yml"
          },
          "outputs": {
            "makefile": "{{ cookiecutter.service_slug }}/Makefile"
          },
          "estimated_cost": 4.0
        },
        {
          "id": "TASK-015",
          "title": "Create documentation templates",
          "description": "Generate DEPLOYMENT.md, DEVELOPMENT.md, OPERATIONS.md, README.md, and CLAUDE.md",
          "dependencies": [
            "TASK-014"
          ],
          "specification": {
            "DEPLOYMENT.md": "Helm, ArgoCD, cloud-specific instructions",
            "DEVELOPMENT.md": "Local setup (docker-compose, prerequisites)",
            "OPERATIONS.md": "Troubleshooting, monitoring, scaling",
            "README.md": "Quick start and doc links",
            "CLAUDE.md": "Project rules and imports"
          },
          "inputs": {},
          "outputs": {
            "docs": [
              "README.md",
              "DEPLOYMENT.md",
              "DEVELOPMENT.md",
              "OPERATIONS.md",
              "CLAUDE.md"
            ]
          },
          "estimated_cost": 6.0
        },
        {
          "id": "TASK-016",
          "title": "Configure cross-repo rules imports in CLAUDE.md",
          "description": "Set up @shared-claude-rules imports for conventions (git, testing, secrets, docs)",
          "dependencies": [
            "TASK-015"
          ],
          "specification": {
            "imports": [
              "@shared-claude-rules/workflow/git.md",
              "@shared-claude-rules/workflow/docs.md",
              "@shared-claude-rules/testing.md",
              "@shared-claude-rules/secrets.md"
            ]
          },
          "inputs": {
            "claude_md_template": "CLAUDE.md"
          },
          "outputs": {
            "configured": "CLAUDE.md with imports"
          },
          "estimated_cost": 2.0
        },
        {
          "id": "TASK-017",
          "title": "Implement post_gen_project.py hook",
          "description": "Implement hook that runs git init, initial commit, GitHub repo creation, tooling setup",
          "dependencies": [
            "TASK-002",
            "TASK-014"
          ],
          "specification": {
            "steps": [
              "git init and initial commit",
              "create git tag for version",
              "Install language-specific tooling (Poetry, go mod, npm)",
              "gh repo create (if enabled)",
              "Setup pre-commit hooks",
              "Run initial tests/validation"
            ]
          },
          "inputs": {
            "hook_template": "hooks/post_gen_project.py"
          },
          "outputs": {
            "hook": "hooks/post_gen_project.py"
          },
          "estimated_cost": 8.0
        },
        {
          "id": "TASK-018",
          "title": "Create language-specific stubs (Python, Go, Node.js)",
          "description": "Generate {{ cookiecutter.service_slug }}/ subdirectories with language-specific scaffolds",
          "dependencies": [
